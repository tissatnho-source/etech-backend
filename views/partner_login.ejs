<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Unified Login - ETECH Engine</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .etech-logo-circle {
            background: radial-gradient(circle, #54b2e6 60%, #2e41bd 62%);
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col justify-between">

    <!-- Header Area -->
    <header class="bg-white shadow-sm border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-6 py-4 flex flex-wrap justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 etech-logo-circle rounded-full flex items-center justify-center font-black text-white text-2xl shadow-md border border-blue-900/10">e</div>
                <span class="text-3xl font-extrabold tracking-tight italic">
                    <span class="text-[#f97316]">E</span><span class="text-[#0284c7]">TECH</span>
                </span>
            </div>
            
            <div class="text-right">
                <span class="text-blue-900 font-black text-2xl italic tracking-tighter">ETECH</span>
                <span class="text-cyan-500 text-xs font-bold tracking-widest block mt-[-4px]">=== MULTI LOGIN TERMINAL ===</span>
            </div>
        </div>
        
        <div class="bg-[#1e40af] text-white text-xs font-semibold py-3">
            <div class="max-w-7xl mx-auto px-6 flex justify-between items-center flex-wrap gap-2">
                <div class="flex gap-6 uppercase tracking-wider">
                    <a href="#" class="hover:text-cyan-300 transition-colors">About ETECH</a>
                    <a href="#" class="hover:text-cyan-300 transition-colors">Become Partner</a>
                    <a href="#" class="hover:text-cyan-300 transition-colors">Contact Us</a>
                </div>
                <div class="flex items-center gap-2 text-slate-200">
                    <i class="fa-solid fa-phone text-cyan-300"></i>
                    <span>Helpline No.- 124-4154700</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Section -->
    <main class="max-w-7xl mx-auto px-6 my-10 w-full flex-grow flex items-center justify-center">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch w-full">
            
            <!-- Left Info Box -->
            <div class="lg:col-span-8 bg-white border border-slate-100 rounded-2xl shadow-xl shadow-slate-100/50 p-8 gap-8 min-h-[400px] flex flex-col md:flex-row items-center">
                <div class="flex-1 space-y-5">
                    <div class="flex items-center gap-2 mb-2">
                        <div class="w-6 h-6 etech-logo-circle rounded-full flex items-center justify-center font-bold text-white text-xs">e</div>
                        <span class="text-slate-800 font-extrabold text-lg tracking-tight"><span class="text-orange-500">E</span>TECH</span>
                    </div>
                    <h1 class="text-3xl lg:text-4xl font-extrabold text-slate-800 tracking-tight leading-tight">
                        Become a Partner with <span class="text-blue-600">ETECH</span>
                    </h1>
                    <p class="text-slate-500 text-sm">One Unified secure portal for Admins, Partners, and System Vendors.</p>
                    <ul class="space-y-3.5 text-slate-600 font-semibold text-sm">
                        <li class="flex items-center gap-3">
                            <span class="bg-blue-50 text-blue-600 p-1.5 rounded-full text-xs"><i class="fa-solid fa-layer-group"></i></span> Multi-Tier Access Control
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="bg-blue-50 text-blue-600 p-1.5 rounded-full text-xs"><i class="fa-solid fa-bolt"></i></span> Instant Processing Engine
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="bg-blue-50 text-blue-600 p-1.5 rounded-full text-xs"><i class="fa-solid fa-shield-halved"></i></span> End-to-End Encryption
                        </li>
                    </ul>
                </div>
                <div class="flex-1 flex justify-center">
                    <div class="w-64 h-64 bg-gradient-to-tr from-blue-50 to-orange-50/50 rounded-full flex items-center justify-center border-8 border-white shadow-xl relative overflow-hidden">
                        <span class="text-orange-500/10 text-9xl absolute -right-4 -bottom-4"><i class="fa-solid fa-network-wired"></i></span>
                        <span class="text-blue-600 text-7xl"><i class="fa-solid fa-users-gear"></i></span>
                    </div>
                </div>
            </div>

            <!-- Right Login Form Card -->
            <div class="lg:col-span-4 bg-white border border-slate-100 rounded-2xl shadow-xl shadow-slate-100/50 p-6 flex flex-col justify-center min-h-[400px]">
                <div class="text-center mb-6">
                    <h3 class="text-slate-800 text-xl font-bold">Terminal Gateway</h3>
                    <p class="text-[11px] text-slate-400 mt-1">Admin / Partner / Vendor Gateway</p>
                </div>

                <!-- Error Messages - English Only -->
                <% if (error) { %>
                    <div class="bg-red-50 text-red-700 text-xs p-3 rounded-xl border border-red-100 mb-4 font-medium flex items-center gap-2">
                        <i class="fa-solid fa-triangle-exclamation text-red-500"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/partner/login" method="POST" class="space-y-4 text-xs" onsubmit="return validateCaptchaForm()">
                    <div>
                        <label class="block text-slate-500 font-bold mb-1.5">User Code / Username</label>
                        <div class="relative">
                            <span class="absolute left-3 top-3.5 text-slate-400"><i class="fa-solid fa-id-card"></i></span>
                            <input type="text" name="username" placeholder="Enter Credentials" required 
                                   class="w-full pl-9 pr-3 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 text-sm bg-slate-50/50">
                        </div>
                    </div>

                    <div>
                        <label class="block text-slate-500 font-bold mb-1.5">Password</label>
                        <div class="relative">
                            <span class="absolute left-3 top-3.5 text-slate-400"><i class="fa-solid fa-lock"></i></span>
                            <input type="password" name="password" placeholder="••••••••" required 
                                   class="w-full pl-9 pr-3 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 text-sm bg-slate-50/50">
                        </div>
                    </div>

                    <!-- Captcha with active Refresh feature -->
                    <div>
                        <div class="bg-slate-50 border border-slate-200 p-2 rounded-xl flex justify-between items-center mb-2">
                            <span id="captchaText" class="text-blue-900 tracking-widest font-black italic text-lg select-none px-4 py-1"></span>
                            <button type="button" onclick="generateCaptcha()" class="text-blue-600 hover:text-blue-800 p-2 text-sm" title="Refresh Captcha">
                                <i class="fa-solid fa-arrows-rotate"></i>
                            </button>
                        </div>
                        <input type="text" id="captchaInput" placeholder="Enter Captcha Code" required 
                               class="w-full px-3 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 text-sm bg-slate-50/50">
                        <p id="captchaError" class="text-red-600 text-[10px] mt-1 hidden font-semibold">Captcha code does not match!</p>
                    </div>

                    <div class="grid grid-cols-2 gap-3 pt-2">
                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition uppercase tracking-wider shadow-md shadow-blue-500/10">
                            LOGIN
                        </button>
                        <button type="reset" class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold py-3 rounded-xl transition uppercase tracking-wider">
                            RESET
                        </button>
                    </div>
                </form>

                <div class="flex justify-between items-center text-[10px] text-blue-600 font-semibold mt-5 border-t border-slate-100 pt-3">
                    <a href="#" class="hover:underline">Forgot Password?</a>
                    <span class="text-slate-300">|</span>
                    <a href="#" class="hover:underline">Forgot User Code?</a>
                </div>
            </div>

        </div>
    </main>

    <!-- Footer Area -->
    <footer class="bg-[#1e40af] text-white text-[10px] py-5 mt-auto">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex gap-4">
                <a href="#" class="hover:underline">Privacy Policy</a>
                <a href="#" class="hover:underline">Terms of Use</a>
                <a href="#" class="hover:underline">Cancellation & Refund Policy</a>
            </div>
            <div class="text-center md:text-right">
                <p>Copyright © 2026 etechsolution.com</p>
                <p class="text-slate-300 mt-0.5">Customer Support Number - 0124-4154700</p>
            </div>
            <div class="flex gap-3.5 text-sm">
                <a href="#" class="hover:text-cyan-300"><i class="fa-brands fa-facebook"></i></a>
                <a href="#" class="hover:text-cyan-300"><i class="fa-brands fa-twitter"></i></a>
                <a href="#" class="hover:text-cyan-300"><i class="fa-brands fa-youtube"></i></a>
                <a href="#" class="hover:text-cyan-300"><i class="fa-brands fa-linkedin"></i></a>
                <a href="#" class="hover:text-cyan-300"><i class="fa-brands fa-instagram"></i></a>
            </div>
        </div>
    </footer>

    <script>
        // Captcha Generator Script
        let currentCaptcha = "";

        function generateCaptcha() {
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
            let result = "";
            for (let i = 0; i < 5; i++) {
                result += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            currentCaptcha = result;
            document.getElementById("captchaText").innerText = result.split("").join(" ");
            document.getElementById("captchaInput").value = "";
            document.getElementById("captchaError").classList.add("hidden");
        }

        function validateCaptchaForm() {
            const userInput = document.getElementById("captchaInput").value.replace(/\s+/g, '').toUpperCase();
            if (userInput !== currentCaptcha) {
                document.getElementById("captchaError").classList.remove("hidden");
                return false; // blocks submit
            }
            return true; // allows submit
        }

        // Generate on Load
        window.onload = generateCaptcha;
    </script>
</body>
</html>
