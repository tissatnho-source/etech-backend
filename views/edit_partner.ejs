<form action="/admin/partner/update/<%= partner._id %>" method="POST" class="row g-3">
    <div class="col-md-6">
        <label>Name</label>
        <input type="text" name="name" value="<%= partner.name %>" class="form-control" required>
    </div>
    <div class="col-md-6">
        <label>Mobile</label>
        <input type="text" name="mobile" value="<%= partner.mobile %>" class="form-control" required>
    </div>
    <div class="col-md-6">
        <label>Email</label>
        <input type="email" name="email" value="<%= partner.email %>" class="form-control">
    </div>
    
    <!-- இதேபோல் முகவரிக்கும் கொடுக்கலாம் -->
    <div class="col-md-6">
        <label>State</label>
        <input type="text" name="state" value="<%= partner.address ? partner.address.state : '' %>" class="form-control">
    </div>

    <div class="col-12 text-center mt-3">
        <button type="submit" class="btn btn-success">Update Details</button>
        <a href="/partner-list" class="btn btn-secondary">Cancel</a>
    </div>
</form>
